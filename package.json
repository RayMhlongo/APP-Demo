{
  "name": "cathdel-creamy-apk-wrapper",
  "version": "1.0.0",
  "private": true,
  "description": "Free Android APK wrapper pipeline for Cathdel Creamy",
  "scripts": {
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "apk:debug": "cd android && gradlew.bat assembleDebug",
    "apk:release": "cd android && gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.4",
    "@capacitor/core": "^7.4.3",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/share": "^7.0.4",
    "jspdf": "^4.2.1"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.3",
    "@capacitor/cli": "^7.4.3"
  }
}
